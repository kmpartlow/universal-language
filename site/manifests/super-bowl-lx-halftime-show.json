{"@context":"http://iiif.io/api/presentation/3/context.json","id":"https://kmpartlow.github.io/universal-language/manifests/super-bowl-lx-halftime-show.json","type":"Manifest","label":{"en":["Super Bowl LX Halftime Show"]},"homepage":[{"id":"https://kmpartlow.github.io/universal-language","type":"Text","label":{"en":["Super Bowl LX Halftime Show"]},"format":"text/html"}],"metadata":[{"label":{"en":["Description"]},"value":{"en":[""]}},{"label":{"en":["Language"]},"value":{"en":["English"]}}],"items":[{"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3","type":"Canvas","duration":772,"annotations":[{"@context":"http://iiif.io/api/presentation/3/context.json","id":"https://kmpartlow.github.io/universal-language/manifests/super_bowl_lx_halftime_show-canvas3-1","type":"AnnotationPage","label":{"en":["Default"]},"items":[{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"\"Qué rico es ser latino\" [How wonderful it is to be Latino]","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Vocal","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=0,3"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"Sugarcane fields \n\nA reminder of the island's colonial history as enslaved people were made to cultivate sugar cane starting in the 1500s. The US took the island by force at the end of the 19th century and set up its own lucrative sugar colony [1]","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Set Design","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=7,9"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"Farmers (jibaros) in traditional PR straw hats (pavas) that farmers would wear to protect themselves from the sun \n\nPavas are a symbol of rural life and PR identity","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Clothing","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=18,23"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"Coco trio stand \n\nCall outs throughout the performance to various roadside stops and real businesses that can be found in the Caribbean and the US","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Set Design","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=42,45"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"Piraguas (shaved ice) stand \n\nAcknowledges the interplay and commonalities among countries in the Americas [2]","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Set Design","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=66,70"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"\"Estás escuchando música de Puerto Rico\" [You're listening to music from Puerto Rico]","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Vocal","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=220,222"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"Concho, the PR crested toad \n\nA species of toad that is native to PR and is considered critically endangered by the IUCN","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Object","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=254,257"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"\"Es porque nunca, nunca dejé de creer en mí\nTú también debería', tú también deberías de creer en ti, Vales más de lo que piensa', créeme\" \n\n[It's because I never, never stopped believing in myself, And you should, you should believe in yourself too, You're more valuable than you think, believe me]","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Vocal","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Call to Action","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=275,289"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"Lady Gaga sporting Flor de Maga, the official flower of PR \n\nThe native flower is a symbol of strength, resilience and beauty \n\nThe salsa adaptation of her song calls out to the calls for Bad Bunny to assimilate and translate his own songs for the performance [3]","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Object","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=308,380"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"\"Mientras uno está vivo, uno debe amar lo más que pueda\" [While one is alive one must love as much as possible]","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Vocal","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Call to Action","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=385,390"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"\"Nueva York\" [New York] \n\nHighlighting the PR community and culture in New York","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Vocal","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Set Design","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=445,450"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"Maria Antonia (Toñita) Cay cameo \n\nStarted the Caribbean Social Club in Williamsburg, which now serves as a hub for the New Yor-ican diaspora community [4]\n","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Set Design","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=526,529"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"Bad Bunny won the Grammy Award for Album of the Year as the first Spanish-language album to ever receive the award \n\nHe was inspired by Latino artists before him, and hopes to remind the next generation, and previous, that progress, success, and fulfillment is achievable","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Vocal","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Call to Action","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=532,543"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"\"No, no sueltes la bandera ni olvides el lelolai, Que no quiero que hagan contigo lo que le pasó a Hawái\" [No, don't let go of the flag nor forget the lelolai, 'Cause I don't want them to do to you what happened to Hawaii] \n\n Ricky Martin, another PR icon, sings a verse from Bad Bunny's song \"Lo Que Le Pasó a Hawaii\"","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Vocal","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Call to Action","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=562,593"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"El Apagón [\"The Blackout\"]\nReference to the socioeconomic issues in PR, specifically the frequent blackouts due to an unreliable power grid that was damaged by Hurrican Maria [5]","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Vocal","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Set Design","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=595,605"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"PR flag used in the pro-independence movement when the U.S. sought control of the island. Banned by the U.S. gov. in 1948. The flag is still associated with the independence movement and anti-colonial sentiment [6]","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Object","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=607,635"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"\"ahora todos quieren ser latino', no, Pero les falta sazón, batería y reggaetón\" [now everyone wants to be Latino, no, But they lack rhythm, drums and reggaetón]","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Vocal","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Critical","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=664,669"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"\"God bless America, Sea […]\" [God bless America, doesn't matter if it's […]] \n\nBringing together the theme of unity, and debasing the centralization of the US as \"America\"","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Vocal","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Cultural","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Set Design","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=715,742"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"\"The only thing more powerful than hate is love\" \n\nPresented on the scoreboard screen, calling for all to spread love","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Set Design","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=724,730"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"\"Seguimo' aquí\" [We are still here] \n\nDespite the attempts to erase Latinos from the US and diminish their presense in the Americas, they are still present, thriving, living, and inspiring","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Vocal","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Call to Action","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Critical","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=744,746"},{"@context":"http://www.w3.org/ns/anno.jsonld","type":"Annotation","motivation":["commenting","tagging"],"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3/page1","body":[{"type":"TextualBody","value":"\"Together, we are America\" \n\nThis phrase is enscribed on the football as a message of unity and love across the Americas, a form of response against the divisive US administration and ICE efforts","format":"text/plain","motivation":"commenting"},{"type":"TextualBody","value":"Visual","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Call to Action","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Critical","format":"text/plain","purpose":"tagging","motivation":"tagging"},{"type":"TextualBody","value":"Object","format":"text/plain","purpose":"tagging","motivation":"tagging"}],"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3#t=744,745"}]}],"items":[{"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show-canvas3/paintings","type":"AnnotationPage","items":[{"id":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show-canvas3/paintings","type":"Annotation","motivation":"painting","body":{"id":"https://ia902908.us.archive.org/23/items/bad-bunny-superbowl/Bad%20Bunny%20Superbowl.mp4","type":"Video","format":"video/mp4","duration":772},"target":"https://kmpartlow.github.io/universal-language/super_bowl_lx_halftime_show/canvas/3"}]}]}]}
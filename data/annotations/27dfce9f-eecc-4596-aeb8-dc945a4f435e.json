      "start_time": 791,
      "end_time": 793,
      "annotation": [
        {
          "type": "paragraph",
          "children": [
            {
              "text": "\"Game Over\" in the stadium audience lights, suggesting the loss of the American government as we know it, and a call to action for change"
            }
          ]
        }
      ],

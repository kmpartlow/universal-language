    {
      "start_time": 22,
      "end_time": 30,
      "annotation": [
        {
          "text": "Salutations, it's your uncle, Sam\nAnd this is the great American game [Uncle Sam] "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Parallel between the Super Bowl game and the game of politics "
        },
        {
          "type": "line-break",
          "children": [
            {
              "text": ""
            }
          ]
        },
        {
          "text": "Uncle Sam appropriation as a nod to the \"Uncle Tom\" stereotype"
        }
      ],
      "tags": [
        {
          "tag": "Vocal",
          "category": "Mode"
        },
        {
          "tag": "Visual",
          "category": "Mode"
        },
        {
          "tag": "Critical",
